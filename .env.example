# ── Google AI Studio (primary Gen AI) ──
# Create a key: https://aistudio.google.com/apikey
# Copy to `.env.local` in the project root
GOOGLE_AI_API_KEY=

# Optional: preferred model try-order (comma-separated).
# Leave unset to auto-discover models from Google and use any with quota left.
# GOOGLE_AI_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash

# Aliases also accepted:
# GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# ── MongoDB memory + operational store ──
# Atlas free tier or local: mongodb://127.0.0.1:27017
# When set, app uses MongoDB; otherwise falls back to data/db.json
MONGODB_URI=
MONGODB_DB=stadiachat

# ── Optional fallback: SpaceXAI / xAI ──
# XAI_API_KEY=
# XAI_MODEL=grok-4.5
