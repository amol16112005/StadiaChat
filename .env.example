# Copy to `.env.local` for local dev (never commit real secrets).
# On Render: set the same keys in Dashboard → Environment (see docs/DEPLOY_RENDER.md).

# ── Security (recommended on Render / production) ──
# Long random string for HMAC session cookies
SESSION_SECRET=
# Protect POST /api/admin/reset — send header: x-admin-reset-token: <value>
ADMIN_RESET_TOKEN=

# ── Google AI Studio (primary Gen AI) ──
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Optional: preferred model try-order (comma-separated).
# Leave unset to auto-discover Gemini models and use any with quota left.
# GOOGLE_AI_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash

# Aliases also accepted:
# GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# ── MongoDB (required on Render; optional locally) ──
# Local file fallback: leave MONGODB_URI empty → data/db.json
# Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/
# Local Mongo: mongodb://127.0.0.1:27017
MONGODB_URI=
MONGODB_DB=stadiachat
# Optional: rebuild query mirrors on every write (default: only on reset)
# MONGODB_MIRROR=1

# ── Optional fallback: SpaceXAI / xAI ──
# XAI_API_KEY=
# XAI_MODEL=grok-4.5
